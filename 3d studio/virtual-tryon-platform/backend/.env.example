# Comma-separated origins for CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# placeholder = PIL composite demo (no GPU)
# remote = POST person + garment to REMOTE_TRYON_URL (CatVTON / Gradio / your API)
# huggingface = same as remote (CatVTON is not on the generic HF Inference API)
TRYON_MODE=placeholder

# Full URL that accepts multipart/form-data with files: person, garment (optional mask)
# Example after you expose CatVTON: https://your-server.com/api/tryon
REMOTE_TRYON_URL=
