{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "VITE_TRYON_BACKEND": "https://threed-studio-deploymentt.onrender.com"
  },
  "headers": [
    {
      "source": "/((?!studio(?:/|$)|garment-3d(?:/|$)|phone-capture(?:/|$)).*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/phone-capture", "destination": "/phone-capture/index.html" },
    { "source": "/phone-capture/", "destination": "/phone-capture/index.html" },
    { "source": "/capture/:path*", "destination": "/index.html" },
    { "source": "/ladies_try_on", "destination": "/ladies_try_on/index.html" },
    { "source": "/ladies_try_on/", "destination": "/ladies_try_on/index.html" },
    { "source": "/studio", "destination": "/studio/index.html" },
    { "source": "/studio/", "destination": "/studio/index.html" },
    { "source": "/((?!api/|assets/|garments/|garment-3d/|phone-capture/|ladies-garments/|ladies-catalog/|ladies-resource/|ladies_try_on/).*)", "destination": "/index.html" }
  ]
}
