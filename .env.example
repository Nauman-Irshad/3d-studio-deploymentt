# ─── Local dev (.env) ─── Copy to .env — never commit .env
# On Vercel: Project → Settings → Environment Variables (see DEPLOY_VERCEL.md)

# ─── SERVER ONLY (no VITE_ prefix — never exposed to browser) ───
TRYON_PROVIDER=idm-vton
HF_TOKEN=
TRYON_MOCK=0
TRYON_FAST=1
TRYON_MAX_SIDE=512
TRYON_PERSON_MAX_SIDE=768
TRYON_GARM_MAX_SIDE=512
TRYON_DENOISE_STEPS=20

# Stripe checkout (optional — demo mode without keys)
STRIPE_SECRET_KEY=

# ─── CLIENT SAFE (VITE_ = bundled into frontend — OK for public URLs only) ───
# Do NOT put HF_TOKEN, STRIPE_SECRET_KEY, or any secret here.
VITE_CV_PHONE_URL=https://qr-code-web-deploy.vercel.app/phone-capture
VITE_STRIPE_PUBLISHABLE_KEY=

# Leave unset on Vercel — prod uses same-origin /api
# VITE_TRYON_BACKEND=http://127.0.0.1:8765

# Optional local paths (build sync scripts)
# GARMENT_IMAGES_DIR=E:/fyp whole backend/2D kurta's
# LADIES_CATALOG_DIR=E:/fyp whole backend/id-2d-try-on/ladies all work
